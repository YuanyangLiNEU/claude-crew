# Claude Crew — Configuration
# Copy to .env and fill in: cp .env.example .env

# Bot tokens — get from Telegram @BotFather: /newbot → copy token
ENGINEER_DEVIN_BOT_TOKEN=
ENGINEER_LARK_BOT_TOKEN=
PM_SAGE_BOT_TOKEN=
UX_ARIA_BOT_TOKEN=

# Your Telegram user ID (message @userinfobot to find yours)
# Comma-separated for multiple users. Leave empty to allow all.
ALLOWED_USERS=

# Your name — used in agent profiles and routing
FOUNDER_NAME=
